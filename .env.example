# Copy this to .env and fill in your values
# Never commit .env to version control

# ── Google OAuth2 (for app login) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ── Allowlisted email (only this account can sign in via Google) ──────────────
ALLOWED_EMAIL=your.email@gmail.com

# ── Cookie signing secret — generate with: openssl rand -hex 32 ──────────────
SECRET_KEY=generate_with__openssl_rand_-hex_32

# ── Public domain (both names are supported; APP_BASE_URL takes priority) ─────
APP_BASE_URL=https://your-zeabur-domain.zeabur.app
BASE_URL=https://your-zeabur-domain.zeabur.app

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave blank (or omit) to use in-process storage — no Redis service needed.
# Set this only if you want to connect to an external Redis instance.
# REDIS_URL=redis://localhost:6379

# ── Google Gemini API key (for OCR) ──────────────────────────────────────────
# Get this from https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here
